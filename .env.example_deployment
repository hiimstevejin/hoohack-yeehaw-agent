# Deployment example environment variables
# Copy only the relevant section into each platform:
# - Vercel project: /meet app
# - Separate host: /voice-agent-server

# =========================
# Vercel: /meet Next.js app
# =========================

# LiveKit server-side token generation
LIVEKIT_URL=wss://your-livekit-host.livekit.cloud
LIVEKIT_API_KEY=lkapi_your_production_api_key
LIVEKIT_API_SECRET=your_production_livekit_api_secret

# Supabase server-side access for uploads, ingestion, and persistence
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_DOCUMENT_BUCKET=meet-documents

# Optional; present in current local env but not required by the current server codepaths
SUPABASE_ANON_KEY=your_supabase_anon_key

# Public frontend config
NEXT_PUBLIC_CONN_DETAILS_ENDPOINT=/api/connection-details
NEXT_PUBLIC_SHOW_SETTINGS_MENU=false
# Production frontend should point to the public voice backend WebSocket.
# If omitted locally, the client currently falls back to:
# ws://<current-hostname>:8787/ws on http pages
# wss://<current-hostname>:8787/ws on https pages
NEXT_PUBLIC_VOICE_AGENT_WS_URL=wss://voice.yourdomain.com/ws

# Optional frontend integrations
NEXT_PUBLIC_LK_RECORD_ENDPOINT=
NEXT_PUBLIC_DATADOG_CLIENT_TOKEN=
NEXT_PUBLIC_DATADOG_SITE=datadoghq.com

# API keys currently listed in Deployment.md for the Vercel project
OPENAI_API_KEY=sk-proj-your_openai_key
ASSEMBLYAI_API_KEY=your_assemblyai_key
CARTESIA_API_KEY=your_cartesia_key
CARTESIA_VOICE_ID=f6ff7c0c-e396-40a9-a70b-f7607edb6937
NEWSDATA_API_KEY=your_newsdata_io_api_key

# Optional finance integration used by the voice server tools
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key


# ==========================================
# Separate host: /voice-agent-server service
# ==========================================

# Prefer PORT on managed hosts like Heroku/Fly/Railway if provided automatically.
# Keep VOICE_AGENT_PORT for hosts where you control the process port directly.
PORT=8787
VOICE_AGENT_PORT=8787

# Documentation-only value for the public WebSocket clients should use.
# The current backend code does not read this variable; the frontend uses
# NEXT_PUBLIC_VOICE_AGENT_WS_URL instead.
VOICE_AGENT_PUBLIC_WS_URL=wss://voice.yourdomain.com/ws

# Supabase access for retrieval/document grounding
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_DOCUMENT_BUCKET=meet-documents

# Voice pipeline providers
OPENAI_API_KEY=sk-proj-your_openai_key
ASSEMBLYAI_API_KEY=your_assemblyai_key
CARTESIA_API_KEY=your_cartesia_key
CARTESIA_VOICE_ID=f6ff7c0c-e396-40a9-a70b-f7607edb6937
NEWSDATA_API_KEY=your_newsdata_io_api_key

# Optional finance tool support
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
